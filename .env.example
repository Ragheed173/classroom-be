# Database (Neon)
DATABASE_URL="postgresql://[user]:[password]@[host]/[dbname]?sslmode=require"

# Application
PORT=8000
FRONTEND_URL="http://localhost:5173,https://your-production-frontend.app"

# Better Auth
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:8000"

# Arcjet
ARCJET_KEY="your-arcjet-key"
ARCJET_ENV="development"

# Site24x7 APM (optional — set APMINSIGHT_ENABLED=false to disable)
APMINSIGHT_ENABLED="true"
APMINSIGHT_PORT="8000"
